# Пароль для входа на сайт (придумай свой)
APP_PASSWORD=change-me

# Секрет для подписи сессионной куки (любая длинная случайная строка)
SECRET_KEY=change-me-to-random-string

# Voicer API (озвучка)
# Базовый URL API — возьми из документации Voicer (там, где лежит /openapi.json)
VOICER_API_URL=https://api.voicer.example
VOICER_API_KEY=your-voicer-key

# fast-gen API (картинки / видео)
FASTGEN_API_URL=https://googler.fast-gen.ai
FASTGEN_API_KEY=your-fastgen-key

# Куда складывать задачи и результаты
DATA_DIR=./data

# Порт веб-сервера
PORT=8000
