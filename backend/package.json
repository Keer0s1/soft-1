    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ffprobe-static": "^2.0.3",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
