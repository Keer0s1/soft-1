# --- База данных (PostgreSQL, через pgAdmin 4) ---
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ?schema=public
# Создай базу в pgAdmin (например "soft") и подставь свой пароль от postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soft?schema=public"

# --- Voicer API (озвучка / TTS) ---
VOICER_API_URL="https://voiceapiru.csv666.ru"
VOICER_API_KEY="ВСТАВЬ_КЛЮЧ_VOICER"

# --- fast-gen API (картинки) ---
FASTGEN_API_URL="https://googler.fast-gen.ai"
FASTGEN_API_KEY="ВСТАВЬ_КЛЮЧ_FASTGEN"

# --- Файлы и сервер ---
# Куда складывать озвучку, картинки и готовые ролики
DATA_DIR="./data"
PORT=8000

# Сколько картинок генерировать одновременно (лимит fast-gen — 5)
IMAGE_CONCURRENCY=5

# --- Рендер видео (необязательно) ---
# libx264 (по умолчанию, на процессоре). Если есть NVIDIA — h264_nvenc (в разы быстрее),
# Intel — h264_qsv, AMD — h264_amf.
VIDEO_CODEC="libx264"
# Для libx264: ultrafast / veryfast / fast / medium
VIDEO_PRESET="veryfast"
# Кадров в секунду (для слайдшоу из картинок хватает 24)
VIDEO_FPS=24
